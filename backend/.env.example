# Azure settings — fill in before running
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE_NAME=impressions_generator

BLOB_STORAGE_ACCOUNT_URL=https://yourstorage.blob.core.windows.net
BLOB_CONTAINER_NAME=doctor-notes

OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
OPENAI_API_VERSION=2025-01-01-preview
OPENAI_DEPLOYMENT_NAME=gpt-52

# Azure AI Foundry SDK 2.x (preferred — set this OR OPENAI_ENDPOINT above)
FOUNDRY_PROJECT_CONNECTION_STRING=
FOUNDRY_MODEL_DEPLOYMENT=gpt-52

AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AI_SEARCH_INDEX_NAME=doctor-notes-index
AI_SEARCH_API_KEY=

KEYVAULT_URL=https://your-keyvault.vault.azure.net/

ALLOWED_ORIGINS=http://localhost:3000

APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_EXPORTER_OTLP_ENDPOINT=

AGENT_MAX_REVISIONS=3
GROUNDING_CONFIDENCE_THRESHOLD=0.85
